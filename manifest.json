{
  "manifest_version": 3,
  "name": "Done & Dusted",
  "version": "1.0.0",
  "description": "A minimal, elegant to-do list that replaces your new tab page",
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
